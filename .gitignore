# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Excel temp lock files
~$*.xlsx
.~lock.*

# Output files (workbooks generated by the script)
*_workbook.xlsx
*_workbook.xlsm

# Sensitive / PHI data — never commit Colorado APCD output
*.csv
!sample_input.csv
*.xlsx
!docs/sample_*.xlsx

# Logs and temp
*.log
.cache/
tmp/
